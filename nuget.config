<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <!--
    The porcupine branch targets the user's personal Jellyfin fork (10.12.0 / net10),
    whose Jellyfin.* assemblies are not on nuget.org. CI packs them from
    skalthoff/jellyfin@porcupine into ./porcupine-feed before restore (see
    .github/workflows/publish-repo.yaml). For local builds, populate ./porcupine-feed
    the same way (dotnet pack the Jellyfin.* projects with -p:Version=10.12.0).
  -->
  <packageSources>
    <clear />
    <add key="nuget.org" value="https://api.nuget.org/v3/index.json" />
    <add key="porcupine" value="./porcupine-feed" />
  </packageSources>
</configuration>
